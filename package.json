{
  "name": "auth-service-pg-api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "db:status": "sequelize-cli db:migrate:status",
    "db:pull:hr": "sequelize-auto -h localhost -d hr_db_batch35 -u postgres -x admin -p 5432 -e postgres -o ./src/shared/utils/models/hr -s hr --sg --cls"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^17.4.2",
    "express": "~4.16.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "~1.9.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-auto": "^0.8.8",
    "sequelize-cli": "^6.6.5"
  }
}
